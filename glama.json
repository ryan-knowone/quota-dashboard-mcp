{
  "name": "Quota Dashboard MCP",
  "description": "Local MCP server for real-time AI subscription quota across Claude Code Max, Kimi, and Z.ai.",
  "repository": "https://github.com/ryan-knowone/quota-dashboard-mcp",
  "license": "MIT",
  "category": "developer-tools",
  "tags": ["mcp", "quota", "usage", "claude", "kimi", "zai", "privacy", "local-first"],
  "install": {
    "command": "npx",
    "args": ["-y", "ryan-knowone/quota-dashboard-mcp"]
  },
  "env": {
    "CLAUDE_TOKEN": { "description": "OAuth token from Claude Code browser session", "required": false },
    "KIMI_TOKEN": { "description": "Platform API key from platform.moonshot.cn", "required": false },
    "ZAI_TOKEN": { "description": "Bearer token from Z.ai account", "required": false }
  }
}
